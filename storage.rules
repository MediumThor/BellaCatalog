rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    match /layout-sources/{userId}/{optionId}/{allPaths=**} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    match /layout-sources/{userId}/jobs/{jobId}/{allPaths=**} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    match /layout-previews/{userId}/{optionId}/{allPaths=**} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    match /layout-quote-shares/{userId}/{shareId}/{allPaths=**} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }
  }
}
